---
import BaseLayout from '../layouts/BaseLayout.astro';
import contact from '../content/pages/contact.json';
---

<BaseLayout
  title="Contact — jnutterdev"
  description="Get in touch about a project, job opportunity, or collaboration."
  hideCTA
>
  <section class="section">
    <div class="wrap">
      <div class="article-header">
        <div class="article-header__meta">Contact</div>
        <h1 class="article-header__title" style="white-space: pre-line">{contact.heading}</h1>
      </div>

      <div class="contact-grid">
        <form
          class="contact-form"
          action={`https://formspree.io/f/${contact.formspree_id}`}
          method="POST"
        >
          <input type="hidden" name="_next" value="https://jnutter.dev/thank-you" />
          <div class="form-group">
            <label class="form-label" for="name">Name</label>
            <input
              class="form-input"
              type="text"
              id="name"
              name="name"
              placeholder="Your name"
              required
            />
          </div>
          <div class="form-group">
            <label class="form-label" for="email">Email</label>
            <input
              class="form-input"
              type="email"
              id="email"
              name="email"
              placeholder="your@email.com"
              required
            />
          </div>
          <div class="form-group">
            <label class="form-label" for="message">Message</label>
            <textarea
              class="form-textarea"
              id="message"
              name="message"
              placeholder="Tell me about your project..."
              required
            ></textarea>
          </div>
          <button type="submit" class="btn btn--primary">Send message ↗</button>
        </form>

        <aside class="contact-aside">
          <div class="aside-block">
            <div class="aside-block__label">Email</div>
            <div class="aside-readout">
              <span>{contact.email}</span>
            </div>
          </div>
          <div class="aside-block">
            <div class="aside-block__label">Status</div>
            <div class="aside-readout">
              <span>{contact.status_label}</span><br />
              {contact.status_sub}
            </div>
          </div>
          <div class="aside-block">
            <div class="aside-block__label">Links</div>
            <div class="social-links">
              {contact.social_links.map(link => (
                <a href={link.url} class="social-link" target="_blank" rel="noopener noreferrer">{link.label}</a>
              ))}
            </div>
          </div>
        </aside>
      </div>
    </div>
  </section>
</BaseLayout>

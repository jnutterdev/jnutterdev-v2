---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Contact — jnutterdev"
  description="Get in touch about a project, job opportunity, or collaboration."
  hideCTA
>
  <section class="section">
    <div class="wrap">
      <div class="article-header">
        <div class="article-header__meta">Contact</div>
        <h1 class="article-header__title">
          Let's talk<br />
          about your<br />
          project.
        </h1>
      </div>

      <div class="contact-grid">
        <!-- Replace YOUR_FORM_ID with your Formspree form ID -->
        <form
          class="contact-form"
          action="https://formspree.io/f/YOUR_FORM_ID"
          method="POST"
        >
          <div class="form-group">
            <label class="form-label" for="name">Name</label>
            <input
              class="form-input"
              type="text"
              id="name"
              name="name"
              placeholder="Your name"
              required
            />
          </div>
          <div class="form-group">
            <label class="form-label" for="email">Email</label>
            <input
              class="form-input"
              type="email"
              id="email"
              name="email"
              placeholder="your@email.com"
              required
            />
          </div>
          <div class="form-group">
            <label class="form-label" for="message">Message</label>
            <textarea
              class="form-textarea"
              id="message"
              name="message"
              placeholder="Tell me about your project..."
              required
            ></textarea>
          </div>
          <button type="submit" class="btn btn--primary">Send message ↗</button>
        </form>

        <aside class="contact-aside">
          <div class="aside-block">
            <div class="aside-block__label">Email</div>
            <div class="aside-readout">
              <span>john@jnutterdev.com</span>
            </div>
          </div>
          <div class="aside-block">
            <div class="aside-block__label">Status</div>
            <div class="aside-readout">
              <span>Open to opportunities</span><br />
              Full-time &amp; project work
            </div>
          </div>
          <div class="aside-block">
            <div class="aside-block__label">Links</div>
            <div class="social-links">
              <a href="https://github.com/jnutterdev" class="social-link" target="_blank" rel="noopener noreferrer">GitHub</a>
              <a href="https://www.linkedin.com/in/jnutterdev" class="social-link" target="_blank" rel="noopener noreferrer">LinkedIn</a>
              <a href="https://mastodon.social/@jnutterdev" class="social-link" target="_blank" rel="noopener noreferrer">Mastodon</a>
              <a href="https://bsky.app/profile/jndev.bsky.social" class="social-link" target="_blank" rel="noopener noreferrer">Bluesky</a>
            </div>
          </div>
        </aside>
      </div>
    </div>
  </section>
</BaseLayout>

---
import BaseLayout from '../layouts/BaseLayout.astro';
import about from '../content/pages/about.json';
---

<BaseLayout title="About — jnutterdev" description="Full Stack Developer based in Decatur, GA. I build React interfaces, PHP backends, Astro sites, and the CI/CD pipelines that keep them running.">
  <section class="section">
    <div class="wrap">
      <div class="article-header">
        <div class="article-header__meta">About</div>
        <h1 class="article-header__title" style="white-space: pre-line">{about.heading}</h1>
      </div>

      <div class="about-grid">
        <div>
          <p class="about-bio">{about.bio_1}</p>
          <p class="about-bio">{about.bio_2}</p>

          <div class="skills-block">
            <div class="skills-block__label">Core Dev</div>
            <div class="skills-tags">
              {about.core_skills.map(s => <span class="tag">{s}</span>)}
            </div>
          </div>

          <div class="skills-block">
            <div class="skills-block__label">Tools &amp; Platforms</div>
            <div class="skills-tags">
              {about.tool_skills.map(s => <span class="tag">{s}</span>)}
            </div>
          </div>
        </div>

        <aside class="about-aside">
          <div class="aside-block">
            <div class="aside-block__label">Status</div>
            <div class="aside-readout">
              <span>{about.status_label}</span><br />
              {about.status_sub}
            </div>
          </div>
          <div class="aside-block">
            <div class="aside-block__label">Location</div>
            <div class="aside-readout">
              <span>{about.location}</span><br />
              {about.location_sub}
            </div>
          </div>
          <div class="aside-block">
            <div class="aside-block__label">Find me</div>
            <div class="social-links">
              {about.social_links.map(link => (
                <a href={link.url} class="social-link" target="_blank" rel="noopener noreferrer">{link.label}</a>
              ))}
            </div>
          </div>
        </aside>
      </div>
    </div>
  </section>
</BaseLayout>

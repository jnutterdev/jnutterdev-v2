---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allProjects = await getCollection('projects');
const projects = allProjects
  .sort((a, b) => a.data.order - b.data.order)
  .slice(0, 5);

const allPosts = await getCollection('blog');
const posts = allPosts
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 4);

const allTags = [...new Set(allPosts.flatMap(p => p.data.tags))].sort();
const thisYear = new Date().getFullYear();

function fmtDate(d: Date) {
  return d.toLocaleDateString('en-US', { month: 'short', year: 'numeric' });
}
---

<BaseLayout title="jnutterdev — Full Stack Developer">
  <!-- Hero -->
  <section class="hero">
    <div class="hero__letterform" aria-hidden="true">JN</div>
    <div class="hero__shape" aria-hidden="true"></div>

    <div class="hero__content">
      <div class="hero__wrap">
        <div>
          <div class="hero__label">Full Stack Developer — Decatur, GA</div>
          <h1 class="hero__heading">
            Building<br />
            things<br />
            for the<br />
            web.
          </h1>
          <p class="hero__bio">
            I write clean, maintainable code across the full stack —
            React interfaces, PHP backends, Astro-powered sites,
            and the CI/CD pipelines that keep everything running.
          </p>
          <div class="hero__actions">
            <a href="/projects" class="btn btn--primary">View my work</a>
            <a href="/about" class="btn btn--ghost">About me</a>
          </div>
        </div>

        <div class="hero__aside">
          <div class="data-panel data-panel--status">
            <div class="data-panel__label">Status</div>
            <div class="data-panel__value">Open to opportunities</div>
            <div class="data-panel__sub">Full-time &amp; project work</div>
          </div>
          <div class="data-panel">
            <div class="data-panel__label">Projects</div>
            <div class="data-panel__value data-panel__value--lg">{allProjects.length}</div>
            <div class="data-panel__sub">
              {allProjects.filter(p => p.data.status === 'active').length} active
              / {allProjects.filter(p => p.data.status === 'archived').length} archived
            </div>
          </div>
          <div class="data-panel">
            <div class="data-panel__label">Location</div>
            <div class="data-panel__value">Decatur, GA</div>
            <div class="data-panel__sub">USA — EST / UTC−5</div>
          </div>
          <div class="data-panel">
            <div class="data-panel__label">Latest</div>
            <div class="data-panel__value" style="font-size: 0.9rem;">jnutterdev.com v2</div>
            <div class="data-panel__sub">Astro + Tina CMS</div>
          </div>
        </div>
      </div>
    </div>

    <div class="data-row">
      <div class="data-row__wrap">
        <div class="data-row__item">
          <div class="data-row__num">5+</div>
          <div class="data-row__title">Years Experience</div>
          <div class="data-row__detail">
            HTML / CSS / JS<br />
            React / PHP / Astro
          </div>
        </div>
        <div class="data-row__item">
          <div class="data-row__num">{allProjects.length}</div>
          <div class="data-row__title">Projects Shipped</div>
          <div class="data-row__detail">
            Storefronts, CMS builds<br />
            Tools &amp; open source
          </div>
        </div>
        <div class="data-row__item">
          <div class="data-row__num">40+</div>
          <div class="data-row__title">Commits This Month</div>
          <div class="data-row__detail">
            Active dev across<br />
            multiple repos
          </div>
        </div>
        <div class="data-row__item">
          <div class="data-row__num">v2</div>
          <div class="data-row__title">Site Version</div>
          <div class="data-row__detail">
            Astro + Tina CMS<br />
            Self-hosted VPS
          </div>
        </div>
      </div>
    </div>
  </section>

  <div class="wrap" style="padding-block: 0;"><div class="divider"></div></div>

  <!-- Selected Work -->
  <section class="section">
    <div class="wrap">
      <div class="section-header--row">
        <div>
          <div class="section-eyebrow">
            <span class="section-index">01</span>
            <div class="section-rule"></div>
          </div>
          <h2 class="section-title">Selected<br />Work.</h2>
        </div>
        <a href="/projects" class="view-all">All projects</a>
      </div>

      <div class="projects-grid">
        {projects.map((project, i) => {
          const isFeatured = project.data.featured;
          const cardNum = String(i + 1).padStart(3, '0');
          return (
            <article class={`project-card${isFeatured ? ' project-card--large' : ''}`}>
              <div class="project-card__index">
                PRJ_{cardNum}{isFeatured ? ' — Featured' : ''}
              </div>
              <h3 class="project-card__title">
                <a href={`/projects/${project.id.replace(/\.mdx?$/, '')}`}>{project.data.title}</a>
              </h3>
              <p class="project-card__desc">{project.data.description}</p>
              <div class="project-card__footer">
                <div class="project-card__tags">
                  {project.data.tech.map(t => (
                    <span class={`tag${isFeatured ? ' tag--light' : ''}`}>{t}</span>
                  ))}
                </div>
                <div class="project-card__links">
                  {project.data.github_url && (
                    <a href={project.data.github_url} target="_blank" rel="noopener noreferrer">GitHub ↗</a>
                  )}
                  {project.data.live_url && (
                    <a href={project.data.live_url} target="_blank" rel="noopener noreferrer">Live ↗</a>
                  )}
                </div>
              </div>
            </article>
          );
        })}
      </div>
    </div>
  </section>

  <div class="wrap" style="padding-block: 0;"><div class="divider"></div></div>

  <!-- Latest Writing -->
  <section class="section">
    <div class="wrap">
      <div class="section-header--row">
        <div>
          <div class="section-eyebrow">
            <span class="section-index">02</span>
            <div class="section-rule"></div>
          </div>
          <h2 class="section-title">Latest<br />Writing.</h2>
        </div>
        <a href="/blog" class="view-all">All posts</a>
      </div>

      <div class="writing-layout">
        <div class="post-list">
          {posts.map(post => (
            <a href={`/blog/${post.id.replace(/\.mdx?$/, '')}`} class="post-row">
              <div class="post-row__date">{fmtDate(post.data.date)}</div>
              <div>
                <div class="post-row__title">{post.data.title}</div>
                <div class="post-row__excerpt">{post.data.excerpt}</div>
                {post.data.tags[0] && <span class="post-row__tag">{post.data.tags[0]}</span>}
              </div>
            </a>
          ))}
        </div>

        <aside class="writing-aside">
          <div class="aside-block">
            <div class="aside-block__label">Topics</div>
            <div class="aside-tags">
              {allTags.map(tag => <span class="tag">{tag}</span>)}
            </div>
          </div>
          <div class="aside-block">
            <div class="aside-block__label">Output</div>
            <div class="aside-readout">
              Total posts<br />
              <span>{allPosts.length} entries</span><br /><br />
              Published {thisYear}<br />
              <span>{allPosts.filter(p => p.data.date.getFullYear() === thisYear).length} entries</span><br /><br />
              Avg read time<br />
              <span>~5 min</span>
            </div>
          </div>
          <div class="aside-block">
            <div class="aside-block__label">Format</div>
            <div class="aside-readout">
              Devlogs · Tutorials<br />
              Walkthroughs · Opinions<br />
              Project post-mortems
            </div>
          </div>
        </aside>
      </div>
    </div>
  </section>
</BaseLayout>

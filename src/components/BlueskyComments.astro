---
interface Props {
  blueskyUrl: string;
}

const { blueskyUrl } = Astro.props;

// DID is fixed per handle (resolved once via com.atproto.identity.resolveHandle),
// so it's hardcoded here instead of re-resolved on every load.
const BLUESKY_DID = 'did:plc:qx2x26tndgkpdmzu4yy3xrp4';
const rkey = blueskyUrl.split('/').pop();
const atUri = `at://${BLUESKY_DID}/app.bsky.feed.post/${rkey}`;
---

<section class="bluesky-comments" data-at-uri={atUri}>
  <p class="bluesky-comments__label">Replies on Bluesky</p>
  <div class="bluesky-comments__list" data-comments-list>
    <p class="bluesky-comments__status">Loading replies…</p>
  </div>
</section>

<script>
  interface ReplyAuthor {
    handle: string;
    displayName?: string;
    avatar?: string;
  }

  interface ReplyPost {
    uri: string;
    author: ReplyAuthor;
    record: { text: string; createdAt: string };
    likeCount?: number;
  }

  interface ThreadNode {
    post?: ReplyPost;
    replies?: ThreadNode[];
  }

  function postUrl(uri: string, handle: string) {
    const postRkey = uri.split('/').pop();
    return `https://bsky.app/profile/${handle}/post/${postRkey}`;
  }

  function renderReply(node: ThreadNode): HTMLElement | null {
    if (!node.post) return null;
    const { author, record, likeCount } = node.post;

    const li = document.createElement('li');
    li.className = 'bluesky-comment';

    const link = document.createElement('a');
    link.className = 'bluesky-comment__link';
    link.href = postUrl(node.post.uri, author.handle);
    link.target = '_blank';
    link.rel = 'noopener noreferrer';

    if (author.avatar) {
      const avatar = document.createElement('img');
      avatar.className = 'bluesky-comment__avatar';
      avatar.src = author.avatar;
      avatar.alt = author.displayName || author.handle;
      avatar.loading = 'lazy';
      link.appendChild(avatar);
    }

    const body = document.createElement('div');
    body.className = 'bluesky-comment__body';

    const meta = document.createElement('p');
    meta.className = 'bluesky-comment__meta';

    const name = document.createElement('span');
    name.className = 'bluesky-comment__author';
    name.textContent = author.displayName || author.handle;

    const date = document.createElement('span');
    date.className = 'bluesky-comment__date';
    date.textContent = new Date(record.createdAt).toLocaleDateString('en-US', {
      month: 'short',
      day: 'numeric',
    });

    meta.append(name, date);

    const text = document.createElement('p');
    text.className = 'bluesky-comment__text';
    text.textContent = record.text;

    body.append(meta, text);

    if (likeCount) {
      const likes = document.createElement('span');
      likes.className = 'bluesky-comment__likes';
      likes.textContent = `${likeCount} like${likeCount === 1 ? '' : 's'}`;
      body.appendChild(likes);
    }

    link.appendChild(body);
    li.appendChild(link);

    const childReplies = (node.replies || [])
      .map(renderReply)
      .filter((n): n is HTMLElement => n !== null);
    if (childReplies.length) {
      const nested = document.createElement('ul');
      nested.className = 'bluesky-comment__replies';
      nested.append(...childReplies);
      li.appendChild(nested);
    }

    return li;
  }

  async function loadComments(section: HTMLElement) {
    const atUri = section.dataset.atUri;
    const list = section.querySelector('[data-comments-list]');
    if (!atUri || !list) return;

    try {
      const res = await fetch(
        `https://public.api.bsky.app/xrpc/app.bsky.feed.getPostThread?uri=${encodeURIComponent(atUri)}`
      );
      if (!res.ok) throw new Error(`Bluesky API error: ${res.status}`);
      const { thread } = await res.json();
      const replies: ThreadNode[] = thread?.replies || [];

      list.innerHTML = '';

      if (replies.length === 0) {
        const empty = document.createElement('p');
        empty.className = 'bluesky-comments__status';
        empty.textContent = 'No replies yet — start the conversation on Bluesky.';
        list.appendChild(empty);
        return;
      }

      const ul = document.createElement('ul');
      ul.className = 'bluesky-comment-thread';
      ul.append(...replies.map(renderReply).filter((n): n is HTMLElement => n !== null));
      list.appendChild(ul);
    } catch (err) {
      list.innerHTML = '';
      const error = document.createElement('p');
      error.className = 'bluesky-comments__status';
      error.textContent = 'Could not load replies.';
      list.appendChild(error);
      console.error('Bluesky comments error:', err);
    }
  }

  const section = document.querySelector<HTMLElement>('[data-at-uri]');
  if (section) loadComments(section);
</script>

#!/bin/sh
git fetch origin --quiet

LOCAL=$(git rev-parse @)
REMOTE=$(git rev-parse @{u} 2>/dev/null)

if [ -z "$REMOTE" ]; then
  exit 0
fi

BASE=$(git merge-base @ @{u})

if [ "$LOCAL" != "$REMOTE" ] && [ "$BASE" = "$LOCAL" ]; then
  echo ""
  echo "error: remote has commits you don't have locally."
  echo "  run 'git pull' before pushing to avoid overwriting server changes."
  echo ""
  exit 1
fi
